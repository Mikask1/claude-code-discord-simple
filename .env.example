# Discord Bot Token (from Discord Developer Portal → Bot → Reset Token)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application/Client ID (from Discord Developer Portal → General Information)
DISCORD_CLIENT_ID=your_application_client_id_here

# Anthropic API Key — required if you are not using Claude Code's browser-based login
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: restrict slash command deployment to one guild during development
# Leave blank for global deployment (can take up to 1 hour to propagate)
DISCORD_GUILD_ID=

# Default working directory for Claude Code sessions
# Leave blank to use the directory where the bot process is started
DEFAULT_CWD=

# Comma-separated channel names or IDs where threads get auto-reply behavior
# (typing in a thread triggers Claude automatically, no /ask needed)
# Defaults to any channel named "claudius"
CLAUDIUS_CHANNELS=claudius

# How often (ms) to edit the live Discord message during streaming
# Lower = more responsive; higher = less likely to hit Discord rate limits
STREAM_UPDATE_INTERVAL_MS=3000
